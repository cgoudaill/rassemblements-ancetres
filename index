<style>
*{box-sizing:border-box;margin:0;padding:0}
:root{
  --bg:#0f0e0c;--bg2:#1a1916;--bg3:#242320;
  --gold:#c9a84c;--gold2:#e8c876;--cream:#f5f0e8;
  --text:#f0ece4;--muted:#8a8680;--border:#333230;
  --green:#4a7c59;--red:#7c4a4a;--blue:#4a5e7c;
}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--text);min-height:100vh}
header{background:var(--bg2);border-bottom:1px solid var(--border);padding:1.5rem 2rem;display:flex;align-items:center;justify-content:space-between;position:sticky;top:0;z-index:100}
.logo{display:flex;align-items:center;gap:1rem}
.logo-icon{width:40px;height:40px;border:1.5px solid var(--gold);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:18px}
.logo-text h1{font-family:'Playfair Display',serif;font-size:1.2rem;color:var(--gold2);letter-spacing:.05em}
.logo-text p{font-size:.75rem;color:var(--muted);letter-spacing:.1em;text-transform:uppercase}
.header-stats{display:flex;gap:1.5rem}
.stat{text-align:center}
.stat-n{font-family:'Playfair Display',serif;font-size:1.4rem;color:var(--gold);line-height:1}
.stat-l{font-size:.65rem;color:var(--muted);text-transform:uppercase;letter-spacing:.08em}
.toolbar{background:var(--bg2);border-bottom:1px solid var(--border);padding:.75rem 2rem;display:flex;gap:.75rem;align-items:center;flex-wrap:wrap}
.search-wrap{flex:1;min-width:200px;position:relative}
.search-wrap input{width:100%;background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:.5rem 1rem .5rem 2.2rem;border-radius:6px;font-size:.85rem;font-family:'DM Sans',sans-serif;outline:none}
.search-wrap input:focus{border-color:var(--gold)}
.search-wrap::before{content:'⌕';position:absolute;left:.7rem;top:50%;transform:translateY(-50%);color:var(--muted);font-size:1rem}
.filter-btn{background:var(--bg3);border:1px solid var(--border);color:var(--muted);padding:.45rem .9rem;border-radius:6px;cursor:pointer;font-size:.8rem;font-family:'DM Sans',sans-serif;transition:.2s;white-space:nowrap}
.filter-btn:hover,.filter-btn.active{border-color:var(--gold);color:var(--gold)}
.view-toggle{display:flex;gap:4px;background:var(--bg3);padding:3px;border-radius:6px;border:1px solid var(--border)}
.view-btn{background:none;border:none;color:var(--muted);padding:.3rem .6rem;border-radius:4px;cursor:pointer;font-size:.85rem;transition:.2s}
.view-btn.active{background:var(--gold);color:var(--bg)}
.sort-sel{background:var(--bg3);border:1px solid var(--border);color:var(--text);padding:.45rem .9rem;border-radius:6px;font-size:.8rem;font-family:'DM Sans',sans-serif;outline:none;cursor:pointer}
main{padding:1.5rem 2rem;max-width:1400px;margin:0 auto}
#map-view{display:none;height:500px;border-radius:10px;border:1px solid var(--border);overflow:hidden;margin-bottom:1.5rem}
#map-view.active{display:block}
.grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(320px,1fr));gap:1rem}
.card{background:var(--bg2);border:1px solid var(--border);border-radius:10px;padding:1.25rem;cursor:pointer;transition:.25s;position:relative;overflow:hidden}
.card::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--gold),transparent)}
.card:hover{border-color:var(--gold);transform:translateY(-2px)}
.card-date{font-size:.72rem;color:var(--gold);font-weight:500;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.4rem}
.card-title{font-family:'Playfair Display',serif;font-size:1rem;color:var(--cream);line-height:1.3;margin-bottom:.6rem}
.card-loc{font-size:.78rem;color:var(--muted);margin-bottom:.5rem;display:flex;align-items:center;gap:.3rem}
.card-meta{display:flex;gap:.5rem;flex-wrap:wrap;margin-top:.75rem}
.badge{font-size:.7rem;padding:.2rem .6rem;border-radius:4px;font-weight:500}
.badge-time{background:rgba(201,168,76,.15);color:var(--gold);border:1px solid rgba(201,168,76,.3)}
.badge-price{background:rgba(74,124,89,.2);color:#7ec89a;border:1px solid rgba(74,124,89,.4)}
.badge-price.paid{background:rgba(124,74,74,.2);color:#e89a9a;border:1px solid rgba(124,74,74,.4)}
.badge-dist{background:rgba(74,94,124,.2);color:#9ab0e8;border:1px solid rgba(74,94,124,.4)}
.dist-close{background:rgba(74,124,89,.2);color:#7ec89a;border:1px solid rgba(74,124,89,.4)}
.dist-far{background:rgba(124,74,74,.2);color:#e89a9a;border:1px solid rgba(124,74,74,.4)}
.results-info{color:var(--muted);font-size:.82rem;margin-bottom:1rem}
.empty{text-align:center;padding:3rem;color:var(--muted)}
.modal-overlay{position:fixed;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,.8);z-index:1000;display:none;align-items:center;justify-content:center;padding:1rem}
.modal-overlay.open{display:flex}
.modal{background:var(--bg2);border:1px solid var(--border);border-radius:12px;max-width:600px;width:100%;max-height:90vh;overflow-y:auto;padding:2rem;position:relative}
.modal-close{position:absolute;top:1rem;right:1rem;background:none;border:1px solid var(--border);color:var(--muted);width:30px;height:30px;border-radius:6px;cursor:pointer;font-size:1rem}
.modal-date{font-size:.8rem;color:var(--gold);font-weight:500;letter-spacing:.08em;text-transform:uppercase;margin-bottom:.5rem}
.modal-title{font-family:'Playfair Display',serif;font-size:1.5rem;color:var(--cream);margin-bottom:1rem}
.modal-section{border-top:1px solid var(--border);padding-top:.75rem;margin-top:.75rem}
.modal-label{font-size:.7rem;color:var(--muted);text-transform:uppercase;letter-spacing:.1em;margin-bottom:.25rem}
.modal-value{font-size:.9rem;color:var(--text);line-height:1.5}
.modal-desc{font-size:.85rem;color:var(--muted);line-height:1.6;white-space:pre-line}
.gcal-btn{display:inline-flex;align-items:center;gap:.5rem;background:var(--gold);color:var(--bg);padding:.6rem 1.2rem;border-radius:6px;text-decoration:none;font-size:.85rem;font-weight:500;margin-top:1rem;transition:.2s}
.gcal-btn:hover{background:var(--gold2)}
footer{text-align:center;padding:2rem;color:var(--muted);font-size:.75rem;border-top:1px solid var(--border);margin-top:2rem}
@media(max-width:600px){header{flex-direction:column;gap:1rem}.header-stats{gap:1rem}main{padding:1rem}.toolbar{padding:.75rem 1rem}}
</style>
</head>
