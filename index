function dist(c){const R=6371,lat1=WATERLOO[0]*Math.PI/180,lat2=c[0]*Math.PI/180,dlat=(c[0]-WATERLOO[0])*Math.PI/180,dlng=(c[1]-WATERLOO[1])*Math.PI/180,a=Math.sin(dlat/2)**2+Math.cos(lat1)*Math.cos(lat2)*Math.sin(dlng/2)**2;return Math.round(R*2*Math.atan2(Math.sqrt(a),Math.sqrt(1-a)))}

function fmtDate(d){const months=["janv","févr","mars","avr","mai","juin","juil","août","sept","oct","nov","déc"];const days=["dim","lun","mar","mer","jeu","ven","sam"];const dt=new Date(d+"T12:00:00");return `${days[dt.getDay()]} ${dt.getDate()} ${months[dt.getMonth()]} 2026`}

function isGratuit(p){return p&&(p.toLowerCase().includes('gratuit')||p==='0 €')}

function priceClass(p){return isGratuit(p)?'badge-price':'badge-price paid'}

function distClass(d){return d<=50?'dist-close':'dist-far'}

