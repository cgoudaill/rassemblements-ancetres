<header>
  <div class="logo">
    <div class="logo-icon">🏎</div>
    <div class="logo-text">
      <h1>Rassemblements Ancêtres</h1>
      <p>Belgique &amp; environs · 2026</p>
    </div>
  </div>
  <div class="header-stats">
    <div class="stat"><div class="stat-n" id="stat-total">48</div><div class="stat-l">événements</div></div>
    <div class="stat"><div class="stat-n" id="stat-next">-</div><div class="stat-l">prochains jours</div></div>
    <div class="stat"><div class="stat-n" id="stat-free">-</div><div class="stat-l">gratuits</div></div>
  </div>
</header>

<div class="toolbar">
  <div class="search-wrap">
    <input type="text" id="search" placeholder="Rechercher un événement, une ville...">
  </div>
  <select class="sort-sel" id="sort">
    <option value="date">Trier par date</option>
    <option value="dist">Trier par distance</option>
    <option value="price">Trier par prix</option>
  </select>
  <button class="filter-btn active" data-filter="all">Tous</button>
  <button class="filter-btn" data-filter="gratuit">Gratuits</button>
  <button class="filter-btn" data-filter="proche">≤ 50 km</button>
  <button class="filter-btn" data-filter="avr">Avril</button>
  <button class="filter-btn" data-filter="mai">Mai+</button>
  <div class="view-toggle">
    <button class="view-btn active" data-view="grid" title="Grille">⊞</button>
    <button class="view-btn" data-view="map" title="Carte">◉</button>
  </div>
</div>

<main>
  <p class="results-info" id="results-info"></p>
  <div id="map-view"></div>
  <div class="grid" id="grid"></div>
  <div class="empty" id="empty" style="display:none">Aucun événement trouvé</div>
</main>

<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" id="modal-close">✕</button>
    <div class="modal-date" id="m-date"></div>
    <div class="modal-title" id="m-title"></div>
    <div class="modal-section">
      <div class="modal-label">📍 Lieu</div>
      <div class="modal-value" id="m-loc"></div>
    </div>
    <div class="modal-section" id="m-time-sec">
      <div class="modal-label">🕐 Horaire</div>
      <div class="modal-value" id="m-time"></div>
    </div>
    <div class="modal-section">
      <div class="modal-label">💶 Prix</div>
      <div class="modal-value" id="m-price"></div>
    </div>
    <div class="modal-section">
      <div class="modal-label">📏 Distance depuis Waterloo</div>
      <div class="modal-value" id="m-dist"></div>
    </div>
    <div class="modal-section" id="m-desc-sec">
      <div class="modal-label">ℹ️ Détails</div>
      <div class="modal-desc" id="m-desc"></div>
    </div>
    <a id="m-gcal" class="gcal-btn" href="#" target="_blank">📅 Voir dans Google Calendar</a>
  </div>
</div>

<footer>
  Mis à jour automatiquement chaque matin · Source : calendrier Google "Rassemblement ancetres" · Waterloo, Belgique comme point de référence
</footer>

