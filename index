  const next30=new Date(today.getTime()+30*24*3600000);
  const upcoming=EVENTS.filter(e=>new Date(e.date)>=today&&new Date(e.date)<=next30).length;
  const free=EVENTS.filter(e=>isGratuit(e.price)).length;
  document.getElementById('stat-total').textContent=EVENTS.length;
  document.getElementById('stat-next').textContent=upcoming;
  document.getElementById('stat-free').textContent=free;
}

