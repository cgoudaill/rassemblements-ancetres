    else if(activeFilter==='proche') matchF=e.distKm<=50;
    else if(activeFilter==='avr') matchF=e.date.startsWith('2026-04');
    else if(activeFilter==='mai') matchF=e.date>='2026-05-01';
    return matchQ&&matchF;
  });
  if(sort==='date') filtered.sort((a,b)=>a.date.localeCompare(b.date));
  else if(sort==='dist') filtered.sort((a,b)=>a.distKm-b.distKm);
  else if(sort==='price') filtered.sort((a,b)=>{const ag=isGratuit(a.price)?0:1,bg=isGratuit(b.price)?0:1;return ag-bg||a.date.localeCompare(b.date)});
  document.getElementById('results-info').textContent=`${filtered.length} événement${filtered.length>1?'s':''} affiché${filtered.length>1?'s':''}`;
  if(currentView==='grid') renderGrid();
  else renderMap();
}

function renderGrid(){
  const grid=document.getElementById('grid');
  grid.innerHTML='';
  if(filtered.length===0){document.getElementById('empty').style.display='block';return}
  document.getElementById('empty').style.display='none';
  filtered.forEach(e=>{
    const d=e.distKm;
    const card=document.createElement('div');
    card.className='card';
    card.innerHTML=`
      <div class="card-date">${fmtDate(e.date)}</div>
      <div class="card-title">${e.title}</div>
      <div class="card-loc">📍 ${e.loc.length>60?e.loc.substr(0,57)+'...':e.loc}</div>
      <div class="card-meta">
        ${e.time?`<span class="badge badge-time">🕐 ${e.time}</span>`:''}
        <span class="badge ${priceClass(e.price)}">${e.price}</span>
        <span class="badge badge-dist ${distClass(d)}">📍 ${d} km</span>
      </div>`;
    card.onclick=()=>openModal(e);
    grid.appendChild(card);
  });
}

function renderMap(){
  const mapDiv=document.getElementById('map-view');
  mapDiv.classList.add('active');
  if(!map){
    map=L.map('map-view').setView([50.5,4.5],8);
    L.tileLayer('https://{s}.basemaps.cartocdn.com/dark_all/{z}/{x}/{y}{r}.png',{attribution:'CartoDB'}).addTo(map);
    L.circleMarker(WATERLOO,{radius:8,color:'#c9a84c',fillColor:'#c9a84c',fillOpacity:1}).addTo(map).bindPopup('<b>Waterloo</b><br>Point de référence');
  }
  map.eachLayer(l=>{if(l instanceof L.CircleMarker&&!l._isWaterloo)map.removeLayer(l)});
  filtered.forEach(e=>{
    const color=isGratuit(e.price)?'#7ec89a':e.distKm<=50?'#9ab0e8':'#c9a84c';
    L.circleMarker(e.coords,{radius:7,color,fillColor:color,fillOpacity:.85,weight:1.5})
      .addTo(map)
      .bindPopup(`<b style="color:#1a1916">${e.title}</b><br>${fmtDate(e.date)}<br>${e.price}<br><b>${e.distKm} km de Waterloo</b>`)
      .on('click',()=>openModal(e));
  });
}

function openModal(e){
  document.getElementById('m-date').textContent=fmtDate(e.date);
  document.getElementById('m-title').textContent=e.title;
  document.getElementById('m-loc').textContent=e.loc;
  const timeSec=document.getElementById('m-time-sec');
  if(e.time){timeSec.style.display='block';document.getElementById('m-time').textContent=e.time}else{timeSec.style.display='none'}
  document.getElementById('m-price').textContent=e.price;
  document.getElementById('m-dist').textContent=`${e.distKm} km (à vol d'oiseau)`;
  const descSec=document.getElementById('m-desc-sec');
  if(e.desc){descSec.style.display='block';document.getElementById('m-desc').textContent=e.desc}else{descSec.style.display='none'}
  document.getElementById('m-gcal').href=e.gcal;
  document.getElementById('modal').classList.add('open');
}

document.getElementById('modal-close').onclick=()=>document.getElementById('modal').classList.remove('open');
document.getElementById('modal').onclick=function(ev){if(ev.target===this)this.classList.remove('open')};
document.getElementById('search').oninput=filterAndRender;
document.getElementById('sort').onchange=filterAndRender;

document.querySelectorAll('.filter-btn').forEach(btn=>{
  btn.onclick=function(){
    document.querySelectorAll('.filter-btn').forEach(b=>b.classList.remove('active'));
    this.classList.add('active');
    activeFilter=this.dataset.filter;
    filterAndRender();
  }
});

document.querySelectorAll('.view-btn').forEach(btn=>{
  btn.onclick=function(){
    document.querySelectorAll('.view-btn').forEach(b=>b.classList.remove('active'));
    this.classList.add('active');
    currentView=this.dataset.view;
    if(currentView==='grid'){
      document.getElementById('map-view').classList.remove('active');
      renderGrid();
    } else {
      renderMap();
    }
  }
});

updateStats();
filterAndRender();
</script>
</body>
</html>
